@'
# Dependencies
node_modules/
.pnpm-store/
.yarn/
.yarn-cache/

# Next.js
.next/
out/

# Build outputs
dist/
build/
coverage/

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# Prisma local database
apps/api/prisma/dev.db
apps/api/prisma/dev.db-journal

# Test outputs
playwright-report/
test-results/
.vitest/
.nyc_output/

# Docker and local runtime files
docker-data/
tmp/
temp/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.swp
*.swo

# Local certificates and secrets
*.pem
*.key
*.crt
*.p12
*.pfx

# Vercel
.vercel/

# Turbo / cache
.turbo/
.cache/

# Misc
*.bak
*.tmp
'@ | Set-Content -Encoding utf8 .gitignore